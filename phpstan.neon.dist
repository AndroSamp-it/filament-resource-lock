includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src

    level: 5

    checkMissingIterableValueType: false

    ignoreErrors:
        # ResourceLock uses forceFill which PHPStan cannot fully resolve.
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::forceFill\(\)#'
